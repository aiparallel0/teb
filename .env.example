# ─── teb — Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Only TEB_JWT_SECRET is truly required for production.
# Everything else has sensible defaults or enables optional features.

# ─── AI Provider (optional — template mode works without any AI keys) ─────────
# Set one or both. With TEB_AI_PROVIDER=auto, Anthropic is preferred if set.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# TEB_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# TEB_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# auto | anthropic | openai — "auto" prefers Anthropic when key is set
# TEB_AI_PROVIDER=auto

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (default: sqlite:///teb.db in working directory)
# DATABASE_URL=sqlite:///teb.db

# ─── Security (REQUIRED in production) ────────────────────────────────────────
# JWT signing secret — CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
TEB_JWT_SECRET=change-me-in-production-not-safe
# JWT_ALGORITHM is always HS256 (not configurable)
# TEB_JWT_EXPIRE_HOURS=168

# Fernet key for encrypting stored API credentials (base64-encoded 32 bytes)
# ⚠️  Without this, credentials are stored UNENCRYPTED in the database!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TEB_SECRET_KEY=

# ─── Executor ─────────────────────────────────────────────────────────────────
# TEB_EXECUTOR_TIMEOUT=30
# TEB_EXECUTOR_MAX_RETRIES=2

# ─── Task limits ──────────────────────────────────────────────────────────────
# MAX_TASKS_PER_GOAL=20

# ─── Payment providers (optional) ─────────────────────────────────────────────
# TEB_MERCURY_API_KEY=
# TEB_MERCURY_BASE_URL=https://api.mercury.com/api/v1
# TEB_STRIPE_API_KEY=
# TEB_STRIPE_BASE_URL=https://api.stripe.com/v1

# ─── CORS (optional — defaults to allow all origins) ─────────────────────────
# ⚠️  "*" allows ALL origins — use only in development! Set specific origins for production.
# Comma-separated list of allowed origins.
# TEB_CORS_ORIGINS=http://localhost:8000,https://yourdomain.com

# ─── Logging ──────────────────────────────────────────────────────────────────
# TEB_LOG_LEVEL=INFO
# TEB_LOG_FORMAT=text  # "text" (default) or "json" (for production/structured logging)

# ─── Deployment ───────────────────────────────────────────────────────────────
# Base URL path prefix (for mounting behind a reverse proxy, e.g. /teb)
# Leave unset or empty for standalone mode (app served at /)
# TEB_BASE_PATH=/teb
# Enable/disable the background execution loop
# TEB_AUTONOMOUS_EXECUTION=true
# How often (seconds) the loop checks for pending tasks
# TEB_AUTONOMOUS_EXECUTION_INTERVAL=30
# Default spending threshold for autopilot (max $ per auto-approved transaction)
# TEB_AUTOPILOT_DEFAULT_THRESHOLD=50.0

# ─── Environment Mode ─────────────────────────────────────────────────────────
# "development" (default) or "production"
# In production: TEB_JWT_SECRET is required, CORS is restricted, debug output is off.
# TEB_ENV=development

# ─── Observability (optional) ─────────────────────────────────────────────────
# Sentry DSN for error tracking. pip install sentry-sdk to enable.
# TEB_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# ─── Redis (optional, recommended for production) ─────────────────────────────
# Used for caching. Falls back to in-memory LRU cache when not set.
# REDIS_URL=redis://localhost:6379/0

# ─── Production Docker Compose ────────────────────────────────────────────────
# These are used by docker-compose.prod.yml for the PostgreSQL database:
# TEB_DB_PASSWORD=your-strong-password-here

# ─── Channel Adapters (optional) ──────────────────────────────────────────────
# TEB_SLACK_BOT_TOKEN=
# TEB_SLACK_SIGNING_SECRET=
# TEB_DISCORD_WEBHOOK_URL=
# TEB_WHATSAPP_TOKEN=
# TEB_WHATSAPP_PHONE_ID=

# ─── Enterprise (optional) ────────────────────────────────────────────────────
# Encryption key for data at rest
# TEB_ENCRYPTION_KEY=
# CDN prefix for static assets
# TEB_CDN_URL=https://cdn.example.com/teb
# Region identifier for multi-region
# TEB_REGION=default
